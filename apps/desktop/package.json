{
  "name": "@codel00p/desktop",
  "version": "0.4.0",
  "description": "Electron control center for codel00p sessions and memory.",
  "author": "codel00p contributors",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --publish never",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "dev.codel00p.desktop",
    "productName": "codel00p",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "artifactName": "codel00p-desktop-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.51.0",
    "@codel00p/sdk": "workspace:*",
    "@codel00p/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "vite": "7.3.5"
  }
}
