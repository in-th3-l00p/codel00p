# Clerk publishable key for the desktop renderer.
# Create an application at https://dashboard.clerk.com and copy its
# publishable key (it starts with pk_test_ or pk_live_).
# Copy this file to `.env` and fill in the value, then restart `pnpm dev:desktop`.
RENDERER_VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the codel00p-cloud service the dashboard reads cloud data from.
RENDERER_VITE_CODEL00P_API_URL=http://localhost:8787

# Optional: path to the codel00p CLI binary for local dashboard data.
# Defaults to the workspace build (core/target/debug/codel00p) or PATH.
# CODEL00P_BIN=/absolute/path/to/codel00p

# Optional: web handoff URL for browser-based sign-in (read by the Electron main
# process). Defaults to the cloud dev server. Set it as a shell env var when
# launching, e.g. `CODEL00P_CONNECT_URL=https://codel00p.dev/connect/desktop`.
# CODEL00P_CONNECT_URL=http://localhost:3000/connect/desktop

# Optional: installation docs URL opened from the "install codel00p" view.
# RENDERER_VITE_INSTALL_DOCS_URL=https://codel00p.dev/docs/installation
